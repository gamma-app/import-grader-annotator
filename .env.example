# Slide-Pair Grader - local config. Copy this file to ".env" and edit:
#
#   cp .env.example .env
#
# REQUIRED for sharing: point SLIDE_GRADER_DATA at your synced Google Drive folder.
# That folder holds decks/, annotations/, and exports/ (auto-created if missing) and
# is the SAME folder for everyone on the team via Google Drive for Desktop.
# Leave it unset to grade against the local ./data folder instead (solo / testing).
#
# macOS (Google Drive for Desktop - Shared drive):
#   SLIDE_GRADER_DATA="$HOME/Library/CloudStorage/GoogleDrive-you@gamma.app/Shared drives/<DriveName>/slide-grader-data"
# Windows (Git Bash):
#   SLIDE_GRADER_DATA="/g/Shared drives/<DriveName>/slide-grader-data"
#
#SLIDE_GRADER_DATA=""

# Optional - where rendered PNGs are cached locally (default: ./.cache/renders).
# Keep this on a LOCAL disk; never point it inside the Drive folder.
#SLIDE_GRADER_CACHE=""

# Optional - local port for the app (default 8000).
#PORT=8000

# ---------------------------------------------------------------------------
# Optional - VLM grader integration (gamma packages/import-evals).
# Lets the app run the import-fidelity graders on slide pairs and show the
# pass/borderline/fail verdict + explanation beside your manual grades.
# Requires the gamma monorepo checked out and the eval-server running:
#   cd <gamma>/packages/server && npx tsx ../eval/scripts/eval-server.ts
# (or `cd <gamma>/packages/eval && yarn dev:eval-server`)
#
# Absolute path to the graders dir in your gamma checkout (REQUIRED to grade):
#IMPORT_EVALS_GRADERS_DIR="$HOME/Documents/gamma/packages/import-evals/graders"
# Local eval-server base URL (default http://127.0.0.1:5190):
#EVAL_SERVER_URL="http://127.0.0.1:5190"
# Base URL the eval-server uses to fetch this app's rendered PNGs. Must match
# the host/port the app is served on (default http://127.0.0.1:8000). If you
# change PORT above, change this too.
#SLIDE_GRADER_SELF_URL="http://127.0.0.1:8000"
# Optional model override (default: each grader.yml's model, claude-sonnet-4-6):
#AI_GRADER_MODEL=""
# Parallel grader requests for deck / all-decks runs (default 3):
#AI_GRADER_CONCURRENCY=3
