# Slide-Pair Grader - local config. Copy this file to ".env" and edit:
#
#   cp .env.example .env
#
# REQUIRED for sharing: point SLIDE_GRADER_DATA at your synced Google Drive folder.
# That folder holds decks/, annotations/, and exports/ (auto-created if missing) and
# is the SAME folder for everyone on the team via Google Drive for Desktop.
# Leave it unset to grade against the local ./data folder instead (solo / testing).
#
# macOS (Google Drive for Desktop - Shared drive):
#   SLIDE_GRADER_DATA="$HOME/Library/CloudStorage/GoogleDrive-you@gamma.app/Shared drives/<DriveName>/slide-grader-data"
# Windows (Git Bash):
#   SLIDE_GRADER_DATA="/g/Shared drives/<DriveName>/slide-grader-data"
#
#SLIDE_GRADER_DATA=""

# Optional - where rendered PNGs are cached locally (default: ./.cache/renders).
# Keep this on a LOCAL disk; never point it inside the Drive folder.
#SLIDE_GRADER_CACHE=""

# Optional - local port for the app (default 8000).
#PORT=8000

# ---------------------------------------------------------------------------
# Optional - VLM ("AI") grader.
# Lets the app run the import-fidelity graders on slide pairs and show the
# pass/borderline/fail verdict + explanation beside your manual grades. Grading
# runs IN-PROCESS: the backend reads the two rendered PNGs and calls Anthropic's
# Messages API directly (see backend/app/llm.py). No gamma monorepo or
# eval-server is required — the grader prompts are vendored under backend/graders/.
#
# Anthropic API key (REQUIRED to grade) — copy it from gamma's .envrc, or use
# your own. Without it the AI status dot stays red and the run buttons disabled.
#ANTHROPIC_API_KEY=""
# API base URL + version (override only for a proxy/gateway; defaults shown):
#ANTHROPIC_BASE_URL="https://api.anthropic.com"
#ANTHROPIC_VERSION="2023-06-01"
# Optional model override (default: each grader.yml's model, claude-sonnet-4-6):
#AI_GRADER_MODEL=""
# Max tokens per grader response (verdict + short reason; default 1024):
#AI_GRADER_MAX_TOKENS=1024
# Parallel grader requests for deck / all-decks runs (default 3):
#AI_GRADER_CONCURRENCY=3
# Optional - use an external graders dir (e.g. a gamma checkout) instead of the
# vendored backend/graders/. Rarely needed:
#IMPORT_EVALS_GRADERS_DIR="$HOME/Documents/gamma/packages/import-evals/graders"
#
# Legacy / no longer used: grading no longer routes through gamma's eval-server,
# so these are ignored (kept only for backward compatibility):
#EVAL_SERVER_URL="http://127.0.0.1:5190"
#SLIDE_GRADER_SELF_URL="http://127.0.0.1:8000"

# ---------------------------------------------------------------------------
# Optional - Grader recalibration (optimize a grader prompt from human labels).
# A one-click "Recalibrate" run in the Failure Mode Directory pools human labels,
# generates candidate prompts, and reports an honest before/after agreement. Uses
# the same ANTHROPIC_API_KEY above. Defaults shown; tune only if needed.
#
# Optimizer model that writes candidate prompts (empty = the grader's own model):
#RECALIBRATE_MODEL=""
# Number of independent candidate prompts generated per run:
#RECALIBRATE_CANDIDATES=5
# Train/validation/test split fractions (comma-separated; train is the remainder):
#RECALIBRATE_SPLIT="0.6,0.2,0.2"
# Temperature for candidate diversity (grading itself always runs at 0.0):
#RECALIBRATE_TEMPERATURE=0.7
# RNG seed for the split + case sampling (reproducible runs):
#RECALIBRATE_SEED=1234
# Per candidate: disagreements shown with images (K) + correct-case anchors (M):
#RECALIBRATE_IMAGE_CASES=12
#RECALIBRATE_ANCHORS=5
# Token cap for the optimizer's {themes, prompt} JSON response:
#RECALIBRATE_MAX_TOKENS=4096
# Smallest dataset (pooled labeled pairs) a recalibration will run on:
#RECALIBRATE_MIN_DATASET=10

# ---------------------------------------------------------------------------
# Optional - PPTX import automation (browser-drives gamma.app to create the
# "current import" pair). Upload a .pptx from the dashboard and the app produces
# input.pdf (via LibreOffice) + current_output.pdf (gamma current import) under
# decks/<slug>/, then renders the pair. Requirements:
#   1. `backend/.venv/bin/playwright install chromium`  (setup.sh does this)
#   2. LibreOffice installed so `soffice` can do PPTX->PDF
#   3. A one-time gamma login:  backend/.venv/bin/python -m app.gamma_login
#
# gamma.app base URL (override for a staging environment):
#GAMMA_BASE_URL="https://gamma.app"
# Where the captured gamma login session (cookies) is stored. Machine-LOCAL and
# SENSITIVE — keep it OUT of the shared data dir. Default: <repo>/.cache/gamma_auth_state.json
#GAMMA_AUTH_STATE_PATH=""
# Run the import browser headless. Set to 0 to watch it (useful when calibrating):
#GAMMA_IMPORT_HEADLESS=1
# Overall per-import time budget in ms (gamma slide-import + generation can take
# minutes for large decks):
#GAMMA_IMPORT_TIMEOUT_MS=600000
# Per-UI-action timeout in ms (waiting for a single button/step to appear/click):
#GAMMA_ACTION_TIMEOUT_MS=20000
# Explicit LibreOffice binary path if `soffice` isn't on PATH (auto-detected if empty):
#SOFFICE_BIN=""
# Advanced - override the gamma UI click-path if its import/export UI changes.
# Mirrors the manual flow: dashboard "Import" -> "AI import" -> upload ->
# "Visual import" -> Continue (import settings) -> Continue (pick a theme) ->
# Continue (slide preview, which starts generation) -> wait for /docs/<id> ->
# "Share" -> "Export" tab -> "Export to PDF". Accessible-name values are
# case-insensitive regexes; *_LABELS are comma-separated.
# Dashboard "Import" menu button (stable test id) + label fallback:
#GAMMA_IMPORT_BUTTON_TESTID="import-doc-button"
#GAMMA_IMPORT_BUTTON_LABEL="Import"
# Dropdown item that opens the AI import page:
#GAMMA_AI_IMPORT_LABEL="AI import"
# URL substring the AI import page lives at (hosts the upload <input>):
#GAMMA_IMPORT_PATH="/create/import"
# The faithful import mode to click after upload. Gamma DEFAULTS to an AI
# "Transform content" redesign, so this must be selected for a real current
# import. Set empty ("") to skip and accept gamma's default mode.
#GAMMA_IMPORT_MODE_LABEL="Visual import"
# "Continue" button label. The flow clicks Continue THREE times: (1) the upload
# screen (after the mode pick), (2) the "Pick a theme" step, then (3) the slide-
# preview step (which starts generation). All three use this label:
#GAMMA_IMPORT_CONTINUE_LABEL="Continue"
# Text on the second ("Pick a theme") step; we wait for it before the 2nd Continue:
#GAMMA_THEME_STEP_HINT="Pick a theme"
# Text on the third (slide-preview) step ("<n> cards total"); we wait for it AND
# for its Continue to enable (disabled while gamma imports slides) before clicking:
#GAMMA_PREVIEW_STEP_HINT="cards total"
# Editor URL (regex) that means "the finished deck is open" (not /create/...):
#GAMMA_DOC_URL_REGEX="/docs/[A-Za-z0-9]"
# Editor export click-path -> PDF download:
#GAMMA_EXPORT_OPEN_LABELS="Share,Export"
#GAMMA_EXPORT_PDF_LABEL="PDF"
